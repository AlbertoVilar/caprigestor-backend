# Imagens publicadas no registry. Docker Hub ou GHCR servem.
BACKEND_IMAGE=docker.io/seu-usuario/caprigestor-backend:2026-03-31
FRONTEND_IMAGE=docker.io/seu-usuario/caprigestor-frontend:2026-03-31

# Porta local do frontend dentro da VPS. O Nginx do host deve publicar 80/443.
FRONTEND_BIND_PORT=8088

# Banco de dados de producao. Nao exponha o PostgreSQL publicamente.
JDBC_URL=jdbc:postgresql://10.0.0.10:5432/caprigestor_prod
DB_USER=caprigestor_app
DB_PASSWORD=trocar-antes-do-deploy

# JWT externo ao container. O compose monta o diretorio em /run/secrets/jwt.
JWT_KEYS_DIR=/opt/caprigestor/secrets/jwt

# CORS e fluxo de reset de senha.
CORS_ORIGINS=https://app.seu-dominio.com
PASSWORD_RESET_FRONTEND_BASE_URL=https://app.seu-dominio.com
PASSWORD_RESET_FROM_ADDRESS=no-reply@seu-dominio.com

# SMTP real.
MAIL_HOST=smtp.seu-provedor.com
MAIL_PORT=587
MAIL_USER=usuario-smtp
MAIL_PASSWORD=trocar-antes-do-deploy
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_TIMEOUT_MS=5000

# Bootstrap admin deve ficar desligado em producao.
CAPRIGESTOR_BOOTSTRAP_ADMIN_ENABLED=false
CAPRIGESTOR_BOOTSTRAP_ADMIN_RESET_PASSWORD=false
CAPRIGESTOR_MESSAGING_ENABLED=false
